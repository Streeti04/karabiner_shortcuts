{
    "description": "Terminal-specific shortcuts",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.apple\\.Terminal$",
                        "^com\\.googlecode\\.iterm2$",
                        "^co\\.zeit\\.hyperterm$",
                        "^co\\.zeit\\.hyper$",
                        "^io\\.alacritty$",
                        "^org\\.alacritty$",
                        "^net\\.kovidgoyal\\.kitty$",
                        "^com\\.mitchellh\\.ghostty$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "description": "Terminal: Control+Shift+X to Cmd+X",
            "from": {
                "key_code": "x",
                "modifiers": {
                    "mandatory": ["control", "shift"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "x",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
