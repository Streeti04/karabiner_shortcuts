{
    "description": "System-wide Control mappings (except Terminal)",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.apple\\.Terminal$",
                        "^com\\.googlecode\\.iterm2$",
                        "^co\\.zeit\\.hyperterm$",
                        "^co\\.zeit\\.hyper$",
                        "^io\\.alacritty$",
                        "^org\\.alacritty$",
                        "^net\\.kovidgoyal\\.kitty$",
                        "^com\\.mitchellh\\.ghostty$"
                    ],
                    "type": "frontmost_application_unless"
                }
            ],
            "description": "System-wide: Control+X to Cmd+X (unless Terminal)",
            "from": {
                "key_code": "x",
                "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "x",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
