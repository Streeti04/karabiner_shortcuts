{
    "description": "Browser: Control + Q/W/L to Command + Q/W/L",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.brave\\.Browser$",
                        "^com\\.google\\.Chrome$",
                        "^org\\.mozilla\\.firefox$",
                        "^com\\.apple\\.Safari$",
                        "^com\\.microsoft\\.edgemac$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "description": "Browser: Control + Q/W/L to Command + Q/W/L",
            "from": {
                "key_code": "q",
                "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "q",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.brave\\.Browser$",
                        "^com\\.google\\.Chrome$",
                        "^org\\.mozilla\\.firefox$",
                        "^com\\.apple\\.Safari$",
                        "^com\\.microsoft\\.edgemac$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "from": {
                "key_code": "w",
                "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "w",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.brave\\.Browser$",
                        "^com\\.google\\.Chrome$",
                        "^org\\.mozilla\\.firefox$",
                        "^com\\.apple\\.Safari$",
                        "^com\\.microsoft\\.edgemac$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "from": {
                "key_code": "l",
                "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "l",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        }
    ]
}
