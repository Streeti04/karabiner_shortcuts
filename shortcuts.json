{
    "description": "Windows/Linux Shortcuts for Mac (Browser, AltGr, Ctrl+A/F/C/V/X/Z, Option-Search)",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.brave\\.Browser$",
                        "^com\\.google\\.Chrome$",
                        "^org\\.mozilla\\.firefox$",
                        "^com\\.apple\\.Safari$",
                        "^com\\.microsoft\\.edgemac$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "description": "Browser: Control + Q/W/L to Command + Q/W/L",
            "from": {
                "key_code": "q",
                "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "q",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^com\\.brave\\.Browser$",
