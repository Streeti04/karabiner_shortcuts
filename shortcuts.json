                }
            },
            "to": [
                {
                    "key_code": "l",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Tap Left Option to open Spotlight Search (Cmd+Space), hold for Option",
            "from": {
                "key_code": "left_option",
                "modifiers": { "optional": ["any"] }
            },
            "to": [{ "key_code": "left_option" }],
            "to_if_alone": [
                {
                    "key_code": "spacebar",
                    "modifiers": ["command"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr (Right Option) + Q -> @",
            "from": {
                "key_code": "q",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "l",
                    "modifiers": ["right_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + 7 -> {",
            "from": {
                "key_code": "7",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "8",
                    "modifiers": ["right_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + 8 -> [",
            "from": {
                "key_code": "8",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "5",
                    "modifiers": ["right_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + 9 -> ]",
            "from": {
                "key_code": "9",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "6",
                    "modifiers": ["right_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + 0 -> }",
            "from": {
                "key_code": "0",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "9",
                    "modifiers": ["right_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + ß -> \\ (Backslash)",
            "from": {
                "key_code": "hyphen",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "7",
                    "modifiers": ["right_option", "left_shift"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + + -> ~ (Tilde)",
            "from": {
                "key_code": "close_bracket",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "n",
                    "modifiers": ["right_option"]
                },
                { "key_code": "spacebar" }
            ],
            "type": "basic"
        },
        {
            "description": "Windows AltGr + < -> | (Pipe)",
            "from": {
                "key_code": "non_us_backslash",
                "modifiers": {
                    "mandatory": ["right_option"],
                    "optional": ["caps_lock"]
                }
            },
            "to": [
                {
                    "key_code": "7",
                    "modifiers": ["right_option"]
                }
            ],
            "type": "basic"
        },
